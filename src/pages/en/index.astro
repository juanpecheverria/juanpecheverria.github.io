---
// Served at /en/ (English, per D-03). Mirror image of ../index.astro — identical
// structure; only dict (en.json) + lang + import depth + switch differ.
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/Hero.astro";
import Section from "../../components/Section.astro";
import Bio from "../../components/Bio.astro";
import Timeline from "../../components/Timeline.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import SkillStrip from "../../components/SkillStrip.astro";
import ContactList from "../../components/ContactList.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import en from "../../i18n/en.json";

const esHome = getRelativeLocaleUrl("es", "/");
---

<BaseLayout lang="en" title={en.title} skipLabel={en.skipLink}>
  <Nav t={en.nav} switchHref={esHome} switchLabel="ES" switchLang="es" />
  <main>
    <Hero name={en.hero.name} role={en.hero.role} pitch={en.hero.pitch} cta={en.hero.cta} />

    <Section id="bio" kicker="01" title={en.sections.bio}>
      <Bio body={en.bio.body} />
    </Section>

    <Section id="trayectoria" kicker="02" title={en.sections.trayectoria}>
      <Timeline entries={en.experience} labels={en.experienceLabels} />
    </Section>

    <Section id="proyectos" kicker="03" title={en.sections.proyectos}>
      <div class="grid gap-6 sm:grid-cols-2">
        {en.projects.map((p) => <ProjectCard project={p} labels={en.projectLabels} />)}
      </div>
      <div class="mt-8">
        <SkillStrip skills={en.skills} />
      </div>
    </Section>

    <Section id="contacto" kicker="04" title={en.sections.contacto}>
      <ContactList contact={en.contact} />
    </Section>
  </main>
  <footer class="mx-auto max-w-[768px] px-6 py-12 text-[0.8125rem] text-fg-subtle">
    <p>© 2026 Juan P. Echeverría</p>
  </footer>
</BaseLayout>
