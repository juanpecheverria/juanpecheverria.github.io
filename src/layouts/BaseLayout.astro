---
// Shared HTML shell. Phase 2 attaches the head meta, fonts, skip-link, and theme
// here. The locale is routed through the `lang` prop so later phases never retrofit it.
// Pages provide the <nav>/<main>/<footer> landmarks (one <h1> in the hero).
import { Font } from "astro:assets";
import { getAbsoluteLocaleUrl } from "astro:i18n";
import "../styles/global.css";

interface Props {
  lang?: string;
  title?: string;
  description?: string;
  skipLabel?: string;
}

const {
  lang = "es",
  title = "Juan P. Echeverría",
  description = "",
  skipLabel = "Saltar al contenido",
} = Astro.props;

// Literal locale for the persistence island (I18N-03) + the head metadata below.
const locale = lang === "en" ? "en" : "es";

// SEO/share head metadata (Phase 5). Every absolute URL derives from Astro.site (a
// config constant) + the current path — never a hard-coded domain (one source of
// truth, Pitfall 2). The non-null assertion keeps a future `site` removal failing loudly.
const site = Astro.site!;
const canonical = new URL(Astro.url.pathname, site).href;
const esUrl = getAbsoluteLocaleUrl("es", "/");
const enUrl = getAbsoluteLocaleUrl("en", "/");
const ogLocale = locale === "en" ? "en_US" : "es_ES";
const ogLocaleAlt = locale === "en" ? "es_ES" : "en_US";

// JSON-LD Person (SEO-03). A build-time-constant, developer-controlled object — the
// Astro-documented XSS-safe set:html use (no user input). Real GitHub + LinkedIn
// profiles land in sameAs (Phase 6); the filter drops any empty/placeholder value.
const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Juan P. Echeverría",
  jobTitle: locale === "en" ? "Data Engineer" : "Ingeniero de datos",
  url: site.href,
  sameAs: [
    "https://github.com/juanpecheverria",
    "https://www.linkedin.com/in/juan-pablo-echeverria/",
  ].filter((u) => u && u !== "#"),
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {/* D-04: self-hosted fonts. Preload only the body font (Inter) per Pitfall 3. */}
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-jetbrains-mono" />
    <title>{title}</title>

    {/* SEO + share metadata (Phase 5). Text-only share card — OG image deferred (D-09 revised). */}
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    {/* Open Graph — TEXT set only (no og:image; deferred, D-09 revised). */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Juan P. Echeverría" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    {/* Twitter — TEXT card (summary, not summary_large_image; no twitter:image). */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {/* JSON-LD Person (SEO-03). set:html carries only JSON.stringify of a build-time constant. */}
    <script type="application/ld+json" set:html={JSON.stringify(person)} />
  </head>
  <body class="bg-bg text-fg font-sans">
    <a
      href="#bio"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded focus:bg-surface focus:px-4 focus:py-2 focus:text-fg"
      >{skipLabel}</a
    >
    <slot />

    {/*
      Language persistence / first-visit-redirect island (I18N-03) — the ONLY redirect
      logic on the site, and the phase's highest-risk code (human-verify gated).
      • Records the EXPLICIT choice when the visitor clicks the language switch.
      • Remembers the language of the page actually being viewed.
      • On a FRESH visit to "/" with a stored 'en' preference, redirects ONCE to the
        HARD-CODED literal /en/ (never a value from storage/URL — open-redirect mitigation
        T-04-REDIR), guarded by a sessionStorage flag, via location.replace (no history,
        no loop). Never redirects from /en/, never on 'es', never auto-detects browser
        language (v2 I18N-04). On "/" it checks the stored pref BEFORE recording 'es', so a
        remembered EN choice is honored rather than erased by simply landing on "/".
      • No-JS / blocked-storage → the visitor stays on the requested URL (every page is
        fully pre-rendered); the toggle link still navigates. The redirect is a convenience,
        never a correctness requirement.
    */}
    <script define:vars={{ locale }}>
      try {
        // 1) Record the explicit choice on a language-switch click (its hreflang is the target).
        var sw = document.querySelector("[data-lang-switch]");
        if (sw) {
          sw.addEventListener("click", function () {
            try {
              localStorage.setItem("preferred-lang", sw.getAttribute("hreflang"));
            } catch (e) {}
          });
        }
        // 2) Remember the viewed language; honor a stored 'en' on "/" before recording 'es'.
        if (locale === "en") {
          localStorage.setItem("preferred-lang", "en");
        } else if (
          location.pathname === "/" &&
          localStorage.getItem("preferred-lang") === "en" &&
          !sessionStorage.getItem("lang-redirected")
        ) {
          sessionStorage.setItem("lang-redirected", "1");
          location.replace("/en/");
        } else {
          localStorage.setItem("preferred-lang", "es");
        }
      } catch (e) {
        /* storage blocked → stay on the requested URL (graceful degradation) */
      }
    </script>
  </body>
</html>
