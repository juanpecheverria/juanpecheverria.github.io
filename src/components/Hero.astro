---
// Hero / identity block (LAYOUT-03, D-09/D-10). Locale-agnostic: name/role/pitch/
// cta via props. Sober typographic single column, ~70vh so "01 Bio" peeks below
// the fold; years-of-experience inline in the pitch; quick-access row. External
// links ship rel="noopener noreferrer" now even with placeholder hrefs (Security
// T-02-03). No terminal/code motif, no split, no background ornament (D-03/D-09).
interface Props {
  name: string;
  role: string;
  pitch: string;
  cta: string;
  cvHref: string;
}
const { name, role, pitch, cta, cvHref } = Astro.props;
---

<section class="mx-auto flex min-h-[70vh] max-w-[768px] flex-col justify-center px-6">
  <h1
    class="font-semibold text-fg"
    style="font-size:clamp(2.5rem,1.8rem + 3.5vw,4rem);line-height:1.1;letter-spacing:-0.02em;"
  >
    {name}
  </h1>
  <p class="mt-4 text-[1.25rem] text-fg-muted">{role}</p>
  <p class="mt-4 max-w-[60ch] text-fg">{pitch}</p>

  {/* Quick-access row (D-10). LinkedIn/GitHub external → secure markup now. */}
  <div class="mt-8 flex flex-wrap items-center gap-8">
    <a
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex min-h-[44px] items-center text-fg hover:text-accent hover:underline focus-visible:text-accent focus-visible:underline"
      >LinkedIn</a
    >
    <a
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex min-h-[44px] items-center text-fg hover:text-accent hover:underline focus-visible:text-accent focus-visible:underline"
      >GitHub</a
    >
    {/* Lead action — accent treatment (Color #4). Same-origin CV download: the
        `download` attr keeps it on-origin, so NO target="_blank" and NO rel (Pitfall 5). */}
    <a
      href={cvHref}
      download
      class="inline-flex min-h-[44px] items-center rounded border border-accent px-4 font-semibold text-accent hover:bg-accent hover:text-accent-ink focus-visible:bg-accent focus-visible:text-accent-ink"
      >{cta}</a
    >
  </div>
</section>
