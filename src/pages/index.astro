---
// Served at /  (Spanish, default locale per D-03). Composes the layout shell from
// the Plan-02 chrome + the Plan-04 section components, all fed from es.json.
// Mirror image of en/index.astro — only dict + lang + import depth + switch differ.
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import Bio from "../components/Bio.astro";
import Timeline from "../components/Timeline.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillStrip from "../components/SkillStrip.astro";
import ContactList from "../components/ContactList.astro";
import Footer from "../components/Footer.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import es from "../i18n/es.json";

const enHome = getRelativeLocaleUrl("en", "/");
---

<BaseLayout lang="es" title={es.title} description={es.seo.description} skipLabel={es.skipLink}>
  <Nav t={es.nav} switchHref={enHome} switchLabel="EN" switchLang="en" />
  <main>
    <Hero
      name={es.hero.name}
      role={es.hero.role}
      pitch={es.hero.pitch}
      cta={es.hero.cta}
      cvHref="/cv/Juan-Echeverria-CV-ES.pdf"
      linkedin={es.contact.linkedin}
      github={es.contact.github}
    />

    <Section id="bio" kicker="01" title={es.sections.bio}>
      <Bio body={es.bio.body} />
    </Section>

    <Section id="trayectoria" kicker="02" title={es.sections.trayectoria}>
      <Timeline entries={es.experience} />
    </Section>

    <Section id="proyectos" kicker="03" title={es.sections.proyectos}>
      <div class="grid gap-6 sm:grid-cols-2">
        {es.projects.map((p) => <ProjectCard project={p} labels={es.projectLabels} />)}
      </div>
      <div class="mt-8">
        <SkillStrip skills={es.skills} />
      </div>
    </Section>

    <Section id="contacto" kicker="04" title={es.sections.contacto}>
      <ContactList contact={es.contact} />
    </Section>
  </main>
  <Footer lang="es" updatedLabel={es.footer.updatedLabel} name={es.hero.name} />
</BaseLayout>
