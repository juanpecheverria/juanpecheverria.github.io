---
// Builds to dist/404.html — GitHub Pages serves this for ANY unknown path
// regardless of locale, so there is ONE 404 page (D-01). Spanish-only (D-02):
// the visitor still understands the "Volver al inicio" link. Minimal & sober
// within the dark/technical theme (D-03). NO Nav and NO section anchors (D-04) —
// those #bio…#contacto targets don't exist off the home page. Wrapped in
// BaseLayout so it inherits the theme tokens, fonts, and global focus ring (D-09).
import BaseLayout from "../layouts/BaseLayout.astro";
import es from "../i18n/es.json";
---

<BaseLayout lang="es" title={es.notFound.title} skipLabel={es.skipLink}>
  <main
    class="mx-auto flex min-h-screen max-w-[768px] flex-col items-center justify-center gap-6 px-6 py-24 text-center"
  >
    {/* The 404 code is the single rationed accent emphasis (UI-SPEC accent rule #5). */}
    <p class="font-mono text-6xl font-semibold tracking-tight text-accent">
      {es.notFound.code}
    </p>
    <p class="text-fg-muted">{es.notFound.message}</p>
    <a
      href="/"
      class="inline-block rounded px-6 py-3 text-fg hover:text-accent focus-visible:text-accent"
      >{es.notFound.homeLink}</a
    >
  </main>
</BaseLayout>
